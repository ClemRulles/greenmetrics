{
  "name": "greenmetrics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "analyze": "ANALYZE=true npm run build",
    "analyze:open": "node scripts/analyze-bundle.mjs",
    "lighthouse": "npm run build && npx @lhci/cli autorun",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "env:check": "tsx scripts/env-check.ts",
    "env:check:prod": "tsx scripts/env-check.ts --env=production",
    "env:check:verbose": "tsx scripts/env-check.ts --verbose",
    "infra:setup": "tsx scripts/infra-setup.ts",
    "infra:setup:staging": "tsx scripts/infra-setup.ts --env=staging",
    "infra:setup:prod": "tsx scripts/infra-setup.ts --env=production",
    "infra:setup:dry-run": "tsx scripts/infra-setup.ts --dry-run",
    "db:ha-test": "tsx scripts/db-ha-selftest.ts",
    "db:ha-test:verbose": "tsx scripts/db-ha-selftest.ts --verbose",
    "db:ha-test:load": "tsx scripts/db-ha-selftest.ts --writes=50 --reads=200",
    "db:migrate:write": "DATABASE_URL=$DATABASE_URL_WRITE npx prisma migrate deploy",
    "dev:dc": "docker compose up --build",
    "dev:dc:down": "docker compose down",
    "dev:dc:logs": "docker compose logs -f",
    "db:psql": "docker compose exec postgres psql -U postgres -d greenmetrics",
    "cdn:warm": "tsx scripts/warm-cache.ts --base http://localhost:3000",
    "cdn:warm:staging": "tsx scripts/warm-cache.ts --base https://staging.example.com --verify",
    "cdn:warm:prod": "tsx scripts/warm-cache.ts --base https://app.example.com --verify",
    "perf:check": "lighthouse http://localhost:3000 --output=json --output-path=./lighthouse-report.json",
    "perf:check:staging": "lighthouse https://staging.example.com --output=json --output-path=./lighthouse-staging.json",
    "perf:budget": "lhci autorun",
    "bundle:analyze": "ANALYZE=true npm run build",
    "postinstall": "playwright install --with-deps || true"
  ,
  "smoke:dev": "node scripts/smoke-dev.mjs"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.3.1",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.14.0",
    "@react-pdf/renderer": "^4.3.0",
    "@sentry/nextjs": "^10.5.0",
    "@types/nodemailer": "^7.0.0",
    "@types/qrcode": "^1.5.5",
    "clsx": "^2.1.1",
    "csv-parse": "^6.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "i18next": "^23.11.5",
    "i18next-resources-to-backend": "^1.1.7",
    "jest-axe": "^10.0.0",
    "lucide-react": "^0.539.0",
    "next": "15.0.0",
    "next-auth": "^4.24.11",
    "nodemailer": "^6.10.1",
    "posthog-node": "^5.7.0",
    "prisma": "^6.14.0",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "^15.1.4",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^15.4.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.62.1",
    "@opentelemetry/exporter-otlp-http": "^0.26.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.203.0",
    "@opentelemetry/resources": "^2.0.1",
    "@opentelemetry/sdk-node": "^0.203.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "@opentelemetry/semantic-conventions": "^1.36.0",
    "@playwright/test": "^1.54.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.14.8",
    "@types/react": "^18.2.73",
    "autoprefixer": "^10.4.19",
    "axe-playwright": "^2.0.2",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.8.0",
    "eslint-config-next": "15.0.0",
    "execa": "^9.6.0",
    "framer-motion": "^12.23.12",
    "husky": "^9.1.4",
    "jsdom": "^24.1.0",
    "open": "^10.2.0",
    "postcss": "^8.4.41",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0",
    "web-vitals": "^5.1.0"
  }
}
